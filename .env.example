# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Admin API key (untuk dashboard). WAJIB diganti di production.
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=dev-admin-key-change-me

# Master encryption key untuk encrypt secret credentials di SQLite
# (PCI-DSS req 3.4 — encryption at rest dengan AES-256-GCM).
# WAJIB 64 hex characters (32 bytes). Generate dengan command yang sama dengan ADMIN_API_KEY.
# Kalau kosong, akan derive dari ADMIN_API_KEY pakai scrypt KDF (less secure tapi
# tetap protect terhadap unauthorized DB read).
ENCRYPTION_KEY=

# Authentication brute-force protection (PCI-DSS req 8.1.6 / 8.1.7)
# Threshold: 10 failed attempts in 15 menit = lockout 15 menit untuk IP itu.
# Untuk strict PCI-DSS compliance, set MAX=6 dan DURATION=1800000 (30 menit).
AUTH_MAX_FAILED_ATTEMPTS=10
AUTH_LOCKOUT_WINDOW_MS=900000
AUTH_LOCKOUT_DURATION_MS=900000


# Client API keys untuk aplikasi internal (multi-tenant).
# Comma-separated kalau lebih dari satu app yang ngonsumsi.
# Kosongkan = mode terbuka (gateway harus di-deploy di network internal isolated).
# Contoh: CLIENT_API_KEYS=app-a-secret-xxxxx,app-b-secret-yyyyy
CLIENT_API_KEYS=

# CORS origin yang diizinkan untuk akses admin (dashboard).
# Comma-separated untuk multi origin. JANGAN pakai * di production.
CORS_ORIGIN=http://localhost:3001


# Trust proxy — set jika gateway berjalan di belakang reverse proxy / load balancer
# (nginx, ELB, Cloudflare). Tanpa ini, rate-limit & req.ip akan baca IP proxy.
# Nilai: false (default) | true | <jumlah hop, mis. 1> | <CIDR / IP list>
TRUST_PROXY=false


# Path file SQLite. Folder ./data akan dibuat otomatis.
# Set ke ":memory:" untuk DB in-memory (data hilang saat restart).
DATABASE_PATH=./data/gateway.db

# Provider order untuk fallback (urutan = prioritas)
# Pilihan: midtrans,xendit,doku,tripay,orderkuota
# Catatan: orderkuota hanya support method=qris, bukan untuk credit_card/transfer.
PROVIDER_ORDER=midtrans,xendit,doku,tripay


# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=200

# Mock provider config (untuk simulasi failure)
# Set ke "true" untuk simulasi provider down
MIDTRANS_FORCE_DOWN=false
XENDIT_FORCE_DOWN=false
DOKU_FORCE_DOWN=false
TRIPAY_FORCE_DOWN=false
ORDERKUOTA_FORCE_DOWN=false


# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_BASE_URL=https://api.sandbox.midtrans.com

# Xendit
XENDIT_SECRET_KEY=
XENDIT_BASE_URL=https://api.xendit.co
# Token untuk verifikasi webhook Xendit (header x-callback-token)
XENDIT_CALLBACK_TOKEN=

# DOKU (https://docs.doku.com)
DOKU_CLIENT_ID=
DOKU_SECRET_KEY=
DOKU_BASE_URL=https://api-sandbox.doku.com

# Tripay (https://tripay.co.id/developer)
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_BASE_URL=https://tripay.co.id/api-sandbox

# OrderKuota — QRIS via integrasi unofficial mobile app
# ─────────────────────────────────────────────────────
# Cara paling gampang dapat token: pakai dashboard /orderkuota → request OTP →
# masukkan OTP → token otomatis tersimpan ke SQLite (override 2 var di bawah).
# Kalau Anda mau hardcode di .env (alternatif), isi manual:
#  - ORDERKUOTA_USERNAME : username login OrderKuota Anda
#  - ORDERKUOTA_AUTH_TOKEN : format "<resellerId>:<token>" yang didapat dari OTP exchange
ORDERKUOTA_USERNAME=
ORDERKUOTA_AUTH_TOKEN=
ORDERKUOTA_BASE_URL=https://app.orderkuota.com/api/v2

# Background worker untuk auto-sync mutasi (default: enabled, interval 30 detik).
# Set DISABLED=true kalau pakai cron eksternal atau multi-instance setup.
ORDERKUOTA_WORKER_DISABLED=false
ORDERKUOTA_WORKER_INTERVAL_MS=30000

# AutoGoPay — QRIS via autogopay.site (https://v1-gateway.autogopay.site)
AUTOGOPAY_API_KEY=
AUTOGOPAY_BASE_URL=https://v1-gateway.autogopay.site
AUTOGOPAY_FORCE_DOWN=false

# ─────────────────────────────────────────────────────────────────
# Telegram Bot — notifikasi event + command interaktif
# ─────────────────────────────────────────────────────────────────
# Bot otomatis kirim notif ke admin saat:
#   - Pembayaran sukses/gagal
#   - Refund dilakukan
#   - Semua provider down (alert critical)
#   - OrderKuota token expired
#
# Command interaktif (admin chat → bot):
#   /stats   /last [n]   /health   /sync   /refund <orderId>   /help
#
# ── Cara setup ──
# 1. Buka @BotFather di Telegram, ketik /newbot, ikuti petunjuk
# 2. BotFather kasih TOKEN — tempel ke TELEGRAM_BOT_TOKEN
# 3. Chat bot Anda (kirim /start), lalu buka:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Cari "chat":{"id":NUMBER} — itu chat ID Anda
# 4. Tempel chat ID ke TELEGRAM_ADMIN_CHAT_IDS (comma-separated kalau multi-admin)
#
# Kalau TELEGRAM_BOT_TOKEN kosong, bot disabled (tidak ada notifikasi sama sekali).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=



